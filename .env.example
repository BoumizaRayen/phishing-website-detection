# ── Paths ──────────────────────────────────────────────────────────────────
# ARTIFACTS_DIR=artifacts        # path to the saved model files
# FETCH_TIMEOUT=10               # HTTP fetch timeout in seconds
# FETCH_RETRIES=2                # number of retries on fetch failure

# ── Risk thresholds ────────────────────────────────────────────────────────
# RISK_LOW_MAX=0.3
# RISK_MEDIUM_MAX=0.6
# RISK_HIGH_MAX=0.85

# ── API ────────────────────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8000
# API_RELOAD=true
# CORS_ORIGINS=*

# ── Optional external services ─────────────────────────────────────────────
# VIRUSTOTAL_API_KEY=your_key_here
